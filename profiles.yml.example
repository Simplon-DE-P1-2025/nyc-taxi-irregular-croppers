# Modèle de connexion dbt → Snowflake pour le DEV LOCAL (auth navigateur / MFA).
#
#   1) Copie ce fichier :            cp profiles.yml.example ~/.dbt/profiles.yml
#   2) Remplace <TON_ORG-TON_ACCOUNT> et <TON_USER> par TES infos (cf. docs/onboarding.md).
#
# `externalbrowser` ouvre le navigateur pour le login MFA → AUCUN secret, mot de passe
# ni clé en clair ici. (La CI, elle, utilise une clé RSA via secrets GitHub, pas ce fichier.)

nyc_taxi:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: "<TON_ORG-TON_ACCOUNT>"   # ex. TPWBVCJ-YT98088 — Snowsight → View account details
      user: "<TON_USER>"                 # ton nom d'utilisateur Snowflake (PAS ton email)
      authenticator: externalbrowser
      role: ACCOUNTADMIN
      database: NYC_TAXI_DB
      warehouse: NYC_TAXI_WH
      schema: PUBLIC          # fallback ; les modèles ciblent STAGING / FINAL via +schema (dbt_project.yml)
      threads: 4
