# Modèle de connexion dbt → Snowflake (auth par clé RSA).
# Copie ce fichier en ~/.dbt/profiles.yml puis exporte les variables d'environnement,
# OU lance dbt avec --profiles-dir <dossier de ce fichier>. AUCUN secret en clair ici.
#
#   export SNOWFLAKE_ACCOUNT="TPWBVCJ-YT98088"        # TON account identifier (région indifférente)
#   export SNOWFLAKE_USER="5AMCHAKA"
#   export SNOWFLAKE_PRIVATE_KEY_PATH="$HOME/.snowflake/nyc_taxi_key.p8"
#
# Détails : docs/setup-snowflake.md

nyc_taxi:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      authenticator: snowflake_jwt
      private_key_path: "{{ env_var('SNOWFLAKE_PRIVATE_KEY_PATH') }}"
      role: ACCOUNTADMIN
      database: NYC_TAXI_DB
      warehouse: NYC_TAXI_WH
      schema: PUBLIC          # défaut ; les modèles ciblent STAGING / FINAL via +schema
      threads: 4
